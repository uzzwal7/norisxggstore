    <!-- ==================== SIGN IN & REGISTER TAB ==================== -->
    <section id="tab-auth" class="tab-view">
      <div class="auth-page-container">

        <div class="auth-card">

          <!-- LEFT SIDE: SIGN IN FORM -->
          <div class="auth-split-panel signin-panel">
            <h2 class="auth-title">Sign In</h2>
            <p class="auth-subtitle">Welcome back! Sign in to access your game vault & past orders.</p>

            <form id="signin-form" onsubmit="handleSignInSubmit(event)">
              <div class="form-group">
                <label for="si-username">Email or Phone Number</label>
                <input type="text" id="si-username" required placeholder="e.g. john@example.com or 9801234567">
              </div>
              <div class="form-group">
                <label for="si-password">Password</label>
                <input type="password" id="si-password" required placeholder="Enter your password">
              </div>

              <div class="form-row auth-actions-row">
                <div class="checkbox-remember">
                  <input type="checkbox" id="si-remember">
                  <label for="si-remember">Remember me</label>
                </div>
                <a href="#" class="forgot-pass-link" onclick="forgotPasswordAlert()">Forgotten password?</a>
              </div>

              <button type="submit" class="auth-submit-btn">SIGN IN</button>
            </form>
            <div class="auth-feedback-msg" id="si-success-msg">
              <i class="fas fa-circle-check"></i> Signed in successfully! Redirecting...
            </div>
          </div>

          <div class="auth-divider"><span>OR</span></div>

          <!-- RIGHT SIDE: REGISTER FORM -->
          <div class="auth-split-panel register-panel">
            <h2 class="auth-title">Register</h2>
            <p class="auth-subtitle">Create an account to track orders and save cart items.</p>

            <form id="register-form" onsubmit="handleRegisterSubmit(event)">
              <div class="form-row-double">
                <div class="form-group">
                  <label for="reg-username">Username</label>
                  <input type="text" id="reg-username" required placeholder="e.g. gamer_noris">
                </div>
                <div class="form-group">
                  <label for="reg-email">Email Address</label>
                  <input type="email" id="reg-email" required placeholder="e.g. email@example.com">
                </div>
              </div>

              <div class="form-row-double">
                <div class="form-group">
                  <label for="reg-phone">Phone Number</label>
                  <input type="tel" id="reg-phone" required placeholder="e.g. 9801234567">
                </div>
                <div class="form-group">
                  <label for="reg-address">Delivery Address</label>
                  <input type="text" id="reg-address" required placeholder="Street/Tole details">
                </div>
              </div>

              <div class="form-row-double">
                <div class="form-group">
                  <label for="reg-country">Country</label>
                  <input type="text" id="reg-country" required placeholder="e.g. Nepal">
                </div>
                <div class="form-group">
                  <label for="reg-postal">Postal Code</label>
                  <input type="text" id="reg-postal" required placeholder="e.g. 44600">
                </div>
              </div>

              <div class="form-row-double">
                <div class="form-group">
                  <label for="reg-pass">Password</label>
                  <input type="password" id="reg-pass" required placeholder="Password">
                </div>
                <div class="form-group">
                  <label for="reg-pass-conf">Confirm Password</label>
                  <input type="password" id="reg-pass-conf" required placeholder="Re-enter password">
                </div>
              </div>

              <button type="submit" class="auth-submit-btn reg-btn">CREATE ACCOUNT</button>
            </form>
            <div class="auth-feedback-msg" id="reg-success-msg">
              <i class="fas fa-circle-check"></i> Account created successfully! Please sign in.
            </div>
          </div>

        </div>

      </div>
    </section>
