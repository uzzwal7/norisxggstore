  <!--
    HERO CAROUSEL — only rendered inside the Home tab, so it only shows
    on the homepage route. The slides themselves come from
    config/carouselSlides.js — edit that file to add/remove/change slides,
    you never need to touch this file for that.
  -->
  <section class="hero-carousel-section" id="hero-carousel">
    <div class="carousel-container">

      <% slides.forEach((slide, i) => { %>
      <div class="carousel-slide <%= i === 0 ? 'active' : '' %> slide-split-design <%= slide.themeClass %>">
        <div class="slide-split-inner">
          <div class="slide-content-col">
            <div class="badge-row">
              <span class="offer-tag <%= slide.badgeClass %>"><i class="fas <%= slide.badgeIcon %>"></i> <%= slide.badgeText %></span>
              <% if (slide.limitedIsBadge) { %>
                <span class="discount-badge-top"><%= slide.limitedText %></span>
              <% } else { %>
                <span class="limited-tag"><%= slide.limitedText %></span>
              <% } %>
            </div>
            <h1 class="slide-title"><%= slide.title %> <span class="<%= slide.accentClass %>"><%= slide.titleAccent %></span></h1>
            <h2 class="slide-subtitle"><%= slide.subtitle %></h2>
            <p class="slide-desc"><%= slide.desc %></p>
            <div class="price-action-box">
              <div class="slide-price">
                <span class="original-price"><%= slide.originalPrice %></span>
                <span class="current-price"><%= slide.currentPrice %></span>
              </div>
              <button class="slide-buy-btn <%= slide.buttonClass %>" onclick="buyItemDirectly('<%= slide.buttonAction %>')">
                <i class="fas fa-shopping-bag"></i> <%= slide.buttonText %>
              </button>
            </div>
            <div class="slide-features">
              <% slide.features.forEach(f => { %>
                <span><i class="fas <%= f.icon %>"></i> <%= f.text %></span>
              <% }) %>
            </div>
          </div>

          <div class="slide-graphic-col">
            <div class="banner-graphic-sphere <%= slide.sphereClass %>">
              <!-- Your image goes here (see config/carouselSlides.js). Falls back to an icon if missing. -->
              <% if (slide.image) { %>
                <img class="banner-graphic-img" src="<%= slide.image %>" alt="<%= slide.title %> <%= slide.titleAccent %>"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
              <% } %>
              <div class="glowing-trophy-overlay <%= slide.fallbackGlowClass %>" style="<%= slide.image ? 'display:none;' : '' %>">
                <i class="fas <%= slide.fallbackIcon %>"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% }) %>

      <!-- Carousel Navigation Arrows -->
      <button class="carousel-arrow prev" onclick="changeSlide(-1)"><i class="fas fa-chevron-left"></i></button>
      <button class="carousel-arrow next" onclick="changeSlide(1)"><i class="fas fa-chevron-right"></i></button>

      <!-- Carousel Dots (auto-generated to match slide count) -->
      <div class="carousel-dots">
        <% slides.forEach((slide, i) => { %>
          <span class="dot <%= i === 0 ? 'active' : '' %>" onclick="setSlide(<%= i %>)"></span>
        <% }) %>
      </div>
    </div>
  </section>
